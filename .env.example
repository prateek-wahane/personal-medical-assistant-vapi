APP_NAME=Personal Medical Assistant
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
JSON_LOGS=false
DATABASE_URL=sqlite:///./medical_assistant.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE_SECONDS=1800
UPLOAD_DIR=./uploads
TIMEZONE=Asia/Kolkata
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.csv
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
AUTH_SECRET_KEY=change-me-in-production
AUTH_SECRET_KEY_FILE=
AUTH_TOKEN_EXP_MINUTES=1440
GOOGLE_CLIENT_SECRETS_FILE=./credentials/google_client_secret.json
GOOGLE_TOKEN_FILE=./credentials/google_token.json
GOOGLE_CALENDAR_ID=primary
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=
VAPI_WEBHOOK_SECRET_FILE=
PUBLIC_BASE_URL=http://localhost:8000
OCR_ENABLED=false
OCR_COMMAND=ocrmypdf
OCR_LANGUAGE=eng
OCR_TIMEOUT_SECONDS=120
OCR_MIN_EXTRACTED_CHARS=80
OCR_FORCE=false
REQUEST_ID_HEADER_NAME=x-request-id
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_UPLOAD_PER_MINUTE=10
RATE_LIMIT_VAPI_PER_MINUTE=120
